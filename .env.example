# Production environment variables for IONOS deployment
# Copy this to .env and fill in your IONOS database details

# Database connection
# For MySQL on IONOS: mysql+pymysql://username:password@hostname:port/database_name
DATABASE_URL=mysql+pymysql://your_db_user:your_db_password@your_ionos_host:3306/your_db_name

# Question seed file (leave as is)
QUESTION_SEED_FILE=app/data/questions.json

# Logging level (INFO for production)
LOG_LEVEL=INFO

# Rate limiting (adjust as needed)
RATE_LIMIT_REQUESTS_PER_MINUTE=120